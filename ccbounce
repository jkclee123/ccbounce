#!/usr/bin/env bash
set -euo pipefail

BOUNCE_FILE="/tmp/ccbounce_target"

if [ $# -lt 1 ]; then
    echo "Usage: ccbounce <directory>" >&2
    exit 1
fi

dir="$1"

if [ ! -d "$dir" ]; then
    echo "Error: '$dir' is not a directory" >&2
    exit 1
fi

# Resolve to absolute path, write BEFORE killing (avoids race)
echo "$(cd "$dir" && pwd -P)" > "$BOUNCE_FILE"

# Kill claude — the cc wrapper will detect bounce file and restart
pkill -f "^claude" || true
pkill -f "script.*claude" || true
