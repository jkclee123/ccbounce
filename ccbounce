#!/usr/bin/env bash
set -euo pipefail

if [ $# -lt 1 ]; then
  echo "Usage: ccbounce <directory>" >&2
  exit 1
fi

dir="$1"

if [ ! -d "$dir" ]; then
  echo "Error: '$dir' is not a directory" >&2
  exit 1
fi

# Pause to allow backgrounding to complete before killing claude
sleep 2

# Kill all claude processes
pkill -f claude || true

# Small delay to let processes exit
sleep 2

# Start claude in the target directory
cd "$dir"
exec script -q /dev/null -c "claude 'say ready' --channels plugin:telegram@claude-plugins-official"
